# Configuración del Microservicio IA
APP_NAME="IA Asistencia Emergencias"
APP_ENV=development
HOST=0.0.0.0
PORT=8001

# Logging
LOG_LEVEL=INFO

# Configuración del Modelo
MODEL_PROVIDER=torch
MODEL_PATH=models/best_mobile.pt

# Token generado con openssl rand -hex 32 (Pega tu token aquí)
SERVICE_TOKEN=tu_token_generado_aqui

# Timeouts and limits
REQUEST_TIMEOUT_SECONDS=20
MAX_IMAGE_SIZE_MB=10
